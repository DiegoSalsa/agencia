# ============================================
# PuroCode — Variables de Entorno
# ============================================
# Copia este archivo como .env (o .env.local) y completa los valores.
# NUNCA subir .env al repositorio.

# --- Base de Datos ---

# Local (SQLite) — usar para desarrollo
DATABASE_URL="file:./dev.db"

# Producción (Turso) — descomentar para producción
# DATABASE_URL="libsql://tu-db.turso.io"
# DATABASE_AUTH_TOKEN="tu-auth-token"

# --- Admin ---

ADMIN_PASSWORD="tu-password-seguro"

# --- Email ---
# Al menos un proveedor de email debe estar configurado.
# El sistema prueba en cascada: Resend → Gmail → Gmail OAuth2 → SendGrid.

# Dirección de envío (requerido)
EMAIL_FROM="PuroCode <tu-email@gmail.com>"

# Opción 1: Gmail App Password (más fácil)
EMAIL_USER="tu-email@gmail.com"
EMAIL_PASS="tu-app-password-de-16-caracteres"

# Opción 2: Resend (recomendado para Vercel)
# RESEND_API_KEY=re_xxxxxxxxxxxx

# Opción 3: Gmail OAuth2
# GMAIL_CLIENT_ID=
# GMAIL_CLIENT_SECRET=
# GMAIL_REFRESH_TOKEN=

# Opción 4: SendGrid
# SENDGRID_API_KEY=

# Desactivar envío de emails (para desarrollo)
# EMAIL_ENABLED=false

# --- Dominios (verificador de disponibilidad) ---
# PORKBUN_API_KEY=
# PORKBUN_SECRET_KEY=

# --- Portal de Clientes ---
# PORTAL_JWT_SECRET=un-string-largo-y-aleatorio-de-al-menos-32-caracteres

# Umbral de precio de dominio en USD. Dominios más caros se muestran como "no disponible".
# DOMAIN_PRICE_THRESHOLD=15
