generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Briefing {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  status      String   @default("nuevo")
  type        String
  clientName  String
  clientEmail String   @default("")
  summary     String?
  contactData String
  contentData String
  designData  String
  extraData   String
}

// ── Portal de Clientes ────────────────────────────────────

model ClientProject {
  id            String   @id @default(uuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Datos del cliente
  clientFirstName  String
  clientLastNameP  String
  clientLastNameM  String?
  clientEmail      String   @unique

  // Datos del proyecto
  projectName   String
  projectUrl    String?
  projectType   String       // "LANDING" | "WEB_CORPORATIVA" | "ECOMMERCE"
  status        String   @default("development")
  // Valores: "development" | "delivered" | "maintenance" | "paused"
  deliveryDate  String?
  technologies  String       // JSON: '["Next.js","Tailwind","Vercel"]'

  // Documentos — JSON: '[{"name":"Briefing.pdf","url":"/docs/..."}]'
  documents     String?

  // Notas internas (solo visible en admin)
  adminNotes    String?

  // Relaciones
  changes       ChangeRequest[]
  tokens        MagicToken[]
}

model ChangeRequest {
  id             String   @id @default(uuid())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  description    String
  priority       String        // "low" | "medium" | "high" | "urgent"
  status         String   @default("pending")
  // Valores: "pending" | "accepted" | "in_progress" | "completed" | "cancelled"

  price          Int?          // CLP — precio real asignado por admin
  estimatedPrice Int?          // CLP — estimación automática del sistema

  completionDate String?
  adminNotes     String?       // Notas internas de PuroCode
  clientNotes    String?       // Respuesta visible para el cliente

  // Relación
  projectId      String
  project        ClientProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model MagicToken {
  id         String   @id @default(uuid())
  token      String   @unique
  expiresAt  DateTime
  used       Boolean  @default(false)

  projectId  String
  project    ClientProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ── Sistema de Ofertas / Promociones ──────────────────────

model Promotion {
  id             String   @id @default(uuid())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Identificación
  title          String              // "Landing Page Profesional"
  slug           String   @unique    // "landing-170k" — used in URLs
  description    String?             // Texto marketing corto

  // Precios
  price          Int                 // Precio oferta en CLP (170000)
  originalPrice  Int                 // Precio original en CLP (220000)

  // Cupos (cosmético)
  totalSlots     Int      @default(10)
  remainingSlots Int      @default(6)

  // Control de visibilidad
  isActive       Boolean  @default(true)
  showBanner     Boolean  @default(true)   // top bar en landing
  showPopup      Boolean  @default(true)   // popup modal
  showPricingCard Boolean @default(true)   // card en sección planes

  // Contenido del banner/popup
  bannerText     String?             // "🔥 Oferta por tiempo limitado"
  popupTitle     String?             // "¡No te lo pierdas!"
  popupBody      String?             // Texto del popup

  // Formulario asociado
  formType       String   @default("LANDING") // Tipo de briefing
  fixedSections  String?  // JSON: '["hero","servicios","portafolio","faq","contacto"]'

  // Fechas opcionales
  startsAt       DateTime?
  endsAt         DateTime?

  // Relaciones
  codes          DiscountCode[]
}

model DiscountCode {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now())

  code        String   @unique          // "PUROCODE20", "AMIGO10"
  type        String   @default("percent") // "percent" | "fixed"
  value       Int                       // 20 (%) o 10000 (CLP)

  maxUses     Int      @default(0)      // 0 = ilimitado
  usedCount   Int      @default(0)
  isActive    Boolean  @default(true)

  // Restricción opcional a una promo
  promotionId String?
  promotion   Promotion? @relation(fields: [promotionId], references: [id], onDelete: SetNull)
}
